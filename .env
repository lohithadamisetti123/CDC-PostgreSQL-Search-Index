# PostgreSQL
POSTGRES_USER=cdc_user
POSTGRES_PASSWORD=cdc_password
POSTGRES_DB=cdc_db
POSTGRES_PORT=5432

# Meilisearch
MEILI_PORT=7700
MEILI_MASTER_KEY=master_key_placeholder
MEILI_INDEX_NAME=products

# CDC Consumer
CDC_PG_HOST=postgres
CDC_PG_PORT=5432
CDC_PG_USER=cdc_user
CDC_PG_PASSWORD=cdc_password
CDC_PG_DB=cdc_db
CDC_REPLICATION_SLOT=my_replication_slot
CDC_PUBLICATION_NAME=my_publication
CDC_LSN_CHECKPOINT_FILE=/data/lsn_checkpoint.txt

# Redis (for SSE event bridge)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CHANNEL=cdc_events

# API/Frontend
API_PORT=8000
API_HOST=0.0.0.0
API_REDIS_HOST=redis
API_REDIS_PORT=6379
API_REDIS_CHANNEL=cdc_events

# Frontend
FRONTEND_PORT=8000

# Submission config (for evaluator)
SUBMISSION_API_BASE_URL=http://localhost:8000
SUBMISSION_SEARCH_INDEX_URL=http://localhost:7700
SUBMISSION_SEARCH_INDEX_API_KEY=master_key_placeholder
